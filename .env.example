# ============================================
# SunDevs Backend - Environment Variables
# ============================================

# --- Required ---

# MongoDB connection string
MONGODB_URI=mongodb://admin:admin123@localhost:27017/sundevs?authSource=admin

# Redis connection string
REDIS_HOST=localhost
REDIS_PORT=6379

# Application port
PORT=3000

# --- Optional ---

# Node environment (default: development)
NODE_ENV=development

# Log level (default: debug) - options: error, warn, log, debug, verbose
LOG_LEVEL=debug

# Pagination defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=50

# Payload size limit in bytes (default: 16384 = 16KB)
MAX_PAYLOAD_SIZE=16384

# Service fee in basis points (default: 500 = 5.00%)
# 100 bp = 1%, 500 bp = 5%, 1000 bp = 10%
SERVICE_FEE_BASIS_POINTS=500
